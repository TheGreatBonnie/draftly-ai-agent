# CockroachDB
COCKROACHDB_URL=postgresql://user:pass@cluster.cockroachlabs.cloud:26257/draftly?sslmode=verify-full

# Requesty (OpenAI-compatible API)
REQUESTY_API_KEY=your-requesty-api-key
REQUESTY_BASE_URL=https://api.requesty.ai/v1
LLM_MODEL=tensorx/deepseek-v4-flash
EMBEDDING_MODEL=azure/openai/text-embedding-3-large@francecentral

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Discord
DISCORD_BOT_TOKEN=...
DISCORD_PUBLIC_KEY=...

# GitHub (Personal Access Token - for outbound API calls)
GITHUB_TOKEN=ghp_...

# GitHub App (for webhook handling and bot authentication)
GITHUB_APP_ID=your-app-id
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
# Clerk (auth + organizations)
CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key
CLERK_SIGNING_SECRET=whsec_your-webhook-signing-secret

# GitHub App slug (used to build the installation URL)
GITHUB_APP_SLUG=your-app-slug

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@draftly.app
SENDGRID_FROM_NAME=Draftly

# Security
SECRET_KEY=change-me-in-production

# Per-stage LLM models (all routed through Requesty)
RESEARCH_MODEL=anthropic/claude-sonnet-4-6
REVIEW_MODEL=anthropic/claude-sonnet-4-6
RUBRIC_GRADER_MODEL=anthropic/claude-haiku-4-5
RUBRIC_MAX_ITERATIONS=3

# App
APP_URL=https://your-app-url.com
REVIEW_DASHBOARD_URL=https://review.your-app-url.com
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# AWS (for CI/CD)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
ECR_REPOSITORY_NAME=draftly

# Staging
STAGING_APP_URL=https://staging.your-app-url.com
STAGING_COCKROACHDB_URL=postgresql://user:pass@staging-cluster.cockroachlabs.cloud:26257/draftly_staging?sslmode=verify-full

# Production
PROD_APP_URL=https://your-app-url.com
