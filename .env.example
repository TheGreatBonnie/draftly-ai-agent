# CockroachDB
COCKROACHDB_URL=postgresql://user:pass@cluster.cockroachlabs.cloud:26257/draftly?sslmode=verify-full

# Requesty (OpenAI-compatible API)
REQUESTY_API_KEY=your-requesty-api-key
REQUESTY_BASE_URL=https://api.requesty.ai/v1
LLM_MODEL=tensorx/deepseek-v4-flash
EMBEDDING_MODEL=azure/openai/text-embedding-3-large@francecentral

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...

# Discord
DISCORD_BOT_TOKEN=...
DISCORD_PUBLIC_KEY=...

# GitHub
GITHUB_TOKEN=ghp_...
GITHUB_WEBHOOK_SECRET=...

# Email (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@draftly.app
SENDGRID_FROM_NAME=Draftly

# Security
SECRET_KEY=change-me-in-production

# Deep agents
DEEPAGENTS_MODEL=anthropic:claude-sonnet-4-6
RUBRIC_GRADER_MODEL=anthropic:claude-haiku-4-5
RUBRIC_MAX_ITERATIONS=3
RESEARCH_MAX_CONCURRENT=3

# App
APP_URL=https://your-app-url.com
REVIEW_DASHBOARD_URL=https://review.your-app-url.com
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO

# AWS (for CI/CD)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
ECR_REPOSITORY_NAME=draftly

# Staging
STAGING_APP_URL=https://staging.your-app-url.com
STAGING_COCKROACHDB_URL=postgresql://user:pass@staging-cluster.cockroachlabs.cloud:26257/draftly_staging?sslmode=verify-full

# Production
PROD_APP_URL=https://your-app-url.com
